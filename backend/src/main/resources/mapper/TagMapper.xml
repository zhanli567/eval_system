<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.evalsystem.tag.mapper.TagMapper">
  <resultMap id="TagSummaryMap" type="com.evalsystem.tag.dto.TagSummary">
    <constructor>
      <arg column="id" javaType="java.lang.String"/>
      <arg column="tagName" javaType="java.lang.String"/>
      <arg column="tagType" javaType="java.lang.String"/>
      <arg column="description" javaType="java.lang.String"/>
      <arg column="createdAt" javaType="java.lang.String"/>
      <arg column="updatedAt" javaType="java.lang.String"/>
    </constructor>
  </resultMap>

  <resultMap id="TagOptionMap" type="com.evalsystem.tag.dto.TagOptionDto">
    <constructor>
      <arg column="id" javaType="java.lang.String"/>
      <arg column="tagId" javaType="java.lang.String"/>
      <arg column="optionName" javaType="java.lang.String"/>
      <arg column="optionGroup" javaType="java.lang.String"/>
      <arg column="displayOrder" javaType="java.lang.Integer"/>
      <arg column="createdAt" javaType="java.lang.String"/>
      <arg column="updatedAt" javaType="java.lang.String"/>
    </constructor>
  </resultMap>

  <resultMap id="TagConfigMap" type="com.evalsystem.tag.dto.TagConfig">
    <constructor>
      <arg column="id" javaType="java.lang.String"/>
      <arg column="tagName" javaType="java.lang.String"/>
      <arg column="tagType" javaType="java.lang.String"/>
      <arg column="description" javaType="java.lang.String"/>
      <arg column="minValue" javaType="java.lang.Integer"/>
      <arg column="maxValue" javaType="java.lang.Integer"/>
      <arg column="passThreshold" javaType="java.lang.Integer"/>
      <arg column="createdAt" javaType="java.lang.String"/>
      <arg column="updatedAt" javaType="java.lang.String"/>
    </constructor>
  </resultMap>

  <select id="listTags" resultMap="TagSummaryMap">
    SELECT id AS id,
           tag_name AS tagName,
           tag_type AS tagType,
           description AS description,
           created_at AS createdAt,
           updated_at AS updatedAt
    FROM eval_tag
    WHERE (#{tagType} IS NULL OR #{tagType} = '' OR tag_type = #{tagType})
      AND (#{like} = '%%' OR tag_name LIKE #{like})
    ORDER BY created_at DESC
    LIMIT #{size} OFFSET #{offset}
  </select>

  <select id="countTags" resultType="long">
    SELECT COUNT(*)
    FROM eval_tag
    WHERE (#{tagType} IS NULL OR #{tagType} = '' OR tag_type = #{tagType})
      AND (#{like} = '%%' OR tag_name LIKE #{like})
  </select>

  <select id="findTagConfig" resultMap="TagConfigMap">
    SELECT id AS id,
           tag_name AS tagName,
           tag_type AS tagType,
           description AS description,
           min_value AS `minValue`,
           max_value AS `maxValue`,
           pass_threshold AS `passThreshold`,
           created_at AS createdAt,
           updated_at AS updatedAt
    FROM eval_tag
    WHERE id = #{tagId}
  </select>

  <select id="listOptions" resultMap="TagOptionMap">
    SELECT id AS id,
           tag_id AS tagId,
           option_name AS optionName,
           option_group AS optionGroup,
           display_order AS displayOrder,
           created_at AS createdAt,
           updated_at AS updatedAt
    FROM eval_tag_option
    WHERE tag_id = #{tagId}
    ORDER BY display_order ASC
  </select>
</mapper>
